# ===================================
# MR. FUEL V2.0 - RAILWAY + RESEND
# ===================================
# Copia este contenido a Railway → Settings → Variables → RAW Editor

NODE_ENV=production
PORT=3000
SESSION_SECRET=mr_fuel_texaco_secret_2024_CAMBIALO_POR_UNA_CLAVE_SEGURA

# ===================================
# EMAIL - RESEND
# ===================================
EMAIL_SERVICE=resend
RESEND_API_KEY=re_TU_API_KEY_AQUI
EMAIL_FROM=Mr. Fuel <onboarding@resend.dev>

# Si tenés dominio verificado en Resend:
# EMAIL_FROM=Mr. Fuel <noreply@tudominio.com>

# ===================================
# DESTINATARIOS DE NOTIFICACIONES
# ===================================
ADMIN_EMAILS=admin@texaco.com,admin2@texaco.com
SUPERVISOR_EMAILS=supervisor@texaco.com,supervisor2@texaco.com

# ===================================
# RECORDATORIOS AUTOMÁTICOS
# ===================================
REMINDER_DAYS=1,3,5
REMINDER_HOUR=08
REMINDER_MINUTE=00

# ===================================
# SISTEMA
# ===================================
TZ=America/Tegucigalpa
BRAND_NAME=Texaco

# ===================================
# ARCHIVOS
# ===================================
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp
MAX_FILE_SIZE=5242880

# ===================================
# RAILWAY - PERSISTENCIA
# ===================================
# Si creaste un volumen en Railway:
RAILWAY_VOLUME_MOUNT_PATH=/data

# URL de la aplicación (Railway lo configura automáticamente):
# APP_URL=https://tu-app.up.railway.app

# ===================================
# NOTAS IMPORTANTES
# ===================================
# 1. Cambia SESSION_SECRET por una clave segura
# 2. Obtén RESEND_API_KEY en: https://resend.com/api-keys
# 3. Actualiza ADMIN_EMAILS y SUPERVISOR_EMAILS con emails reales
# 4. Si tenés dominio propio, verificalo en Resend y actualiza EMAIL_FROM
