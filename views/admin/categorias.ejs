<!DOCTYPE html>
<html lang="es-HN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | Mr. Fuel v2.0</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- include('../partials/pwa-head') %>
</head>
<body>
  <%- include('../partials/header') %>
  
  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">
        <i class="fas fa-list-check"></i> Gestión de Checklist
      </h1>
      <button class="btn btn-primary" data-toggle-modal="nueva-categoria">
        <i class="fas fa-plus"></i> Nueva Categoría
      </button>
    </div>
    
    <% if (categorias.length === 0) { %>
      <div class="card">
        <div style="text-align: center; padding: 40px; color: #666;">
          <i class="fas fa-list-check" style="font-size: 64px; margin-bottom: 20px; opacity: 0.3;"></i>
          <p style="font-size: 18px;">No hay categorías configuradas</p>
          <p>Ejecuta la migración: <code>npm run migrate-v2</code></p>
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <table class="table">
          <thead>
            <tr>
              <th>Orden</th>
              <th>Nombre</th>
              <th>Descripción</th>
              <th>Estación</th>
              <th>Ítems</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% categorias.forEach(cat => { %>
            <tr>
              <td><strong><%= cat.orden %></strong></td>
              <td><%= cat.nombre %></td>
              <td><%= cat.descripcion || '-' %></td>
              <td>
                <% if (cat.estacion_nombre) { %>
                  <span class="badge badge-info">
                    <i class="fas fa-gas-pump"></i> <%= cat.estacion_nombre %>
                  </span>
                <% } else { %>
                  <span class="badge badge-secondary" title="Aplica a todas las estaciones">
                    <i class="fas fa-globe"></i> Todas
                  </span>
                <% } %>
              </td>
              <td><%= cat.total_items %> (<%= cat.items_activos %> activos)</td>
              <td>
                <span class="badge <%= cat.activo ? 'badge-success' : 'badge-danger' %>">
                  <%= cat.activo ? 'Activa' : 'Inactiva' %>
                </span>
              </td>
              <td>
                <a href="/admin/categorias/<%= cat.id %>/items" class="btn btn-sm btn-secondary" title="Ver ítems">
                  <i class="fas fa-list"></i>
                </a>
                <button class="btn btn-sm btn-warning" title="Editar categoría"
                  onclick="abrirEditar(<%= cat.id %>, '<%= cat.nombre.replace(/'/g, "\\'") %>', '<%= (cat.descripcion||'').replace(/'/g, "\\'") %>', <%= cat.orden %>, <%= cat.activo %>, <%= cat.estacion_id || 'null' %>)">
                  <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-sm btn-danger" title="Eliminar categoría"
                  onclick="eliminarCategoria(<%= cat.id %>, '<%= cat.nombre.replace(/'/g, "\\'") %>')">
                  <i class="fas fa-trash"></i>
                </button>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
  
  <!-- Modal: Nueva Categoría -->
  <div id="modal-nueva-categoria" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Nueva Categoría</h2>
        <button class="modal-close" onclick="cerrarModal('modal-nueva-categoria')">&times;</button>
      </div>
      <form action="/admin/categorias/nueva" method="POST">
        <div class="form-group">
          <label>Nombre de la Categoría *</label>
          <input type="text" name="nombre" required class="form-control" placeholder="Ej: CAFETERÍA">
        </div>
        
        <div class="form-group">
          <label>Descripción</label>
          <textarea name="descripcion" class="form-control" rows="3" placeholder="Descripción de la categoría (opcional)"></textarea>
        </div>
        
        <div class="form-group">
          <label>Orden</label>
          <input type="number" name="orden" value="<%= categorias.length + 1 %>" min="1" class="form-control">
          <small class="form-text">Orden en que aparecerá la categoría en las auditorías</small>
        </div>

        <div class="form-group">
          <label><i class="fas fa-gas-pump"></i> Estación de Servicio</label>
          <select name="estacion_id" class="form-control">
            <option value="">— Todas las estaciones —</option>
            <% estaciones.forEach(est => { %>
              <option value="<%= est.id %>"><%= est.nombre %></option>
            <% }); %>
          </select>
          <small class="form-text">
            Asigná este checklist a una estación específica, o dejalo en blanco para que aplique a todas.
          </small>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-nueva-categoria')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar Categoría</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Editar Categoría -->
  <div id="modal-editar-categoria" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Editar Categoría</h2>
        <button class="modal-close" onclick="cerrarModal('modal-editar-categoria')">&times;</button>
      </div>
      <form id="form-editar-categoria" method="POST">
        <div class="form-group">
          <label>Nombre de la Categoría *</label>
          <input type="text" id="edit-nombre" name="nombre" required class="form-control">
        </div>

        <div class="form-group">
          <label>Descripción</label>
          <textarea id="edit-descripcion" name="descripcion" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group">
          <label>Orden</label>
          <input type="number" id="edit-orden" name="orden" min="1" class="form-control">
        </div>

        <div class="form-group">
          <label><i class="fas fa-gas-pump"></i> Estación de Servicio</label>
          <select id="edit-estacion" name="estacion_id" class="form-control">
            <option value="">— Todas las estaciones —</option>
            <% estaciones.forEach(est => { %>
              <option value="<%= est.id %>"><%= est.nombre %></option>
            <% }); %>
          </select>
          <small class="form-text">Dejá en blanco para que aplique a todas las estaciones.</small>
        </div>

        <div class="form-group">
          <label>
            <input type="checkbox" id="edit-activo" name="activo">
            Categoría Activa
          </label>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-editar-categoria')">Cancelar</button>
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar Cambios</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>

  <script>
  // Abrir modal de nueva categoría
  document.querySelectorAll('[data-toggle-modal="nueva-categoria"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('modal-nueva-categoria').style.display = 'flex';
    });
  });

  // Cerrar modal
  function cerrarModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
  }

  // Cerrar modal al hacer clic fuera
  window.addEventListener('click', (e) => {
    if (e.target.classList.contains('modal')) {
      e.target.style.display = 'none';
    }
  });

  // Abrir modal editar con datos precargados
  function abrirEditar(id, nombre, descripcion, orden, activo, estacionId) {
    document.getElementById('edit-nombre').value      = nombre;
    document.getElementById('edit-descripcion').value = descripcion;
    document.getElementById('edit-orden').value       = orden;
    document.getElementById('edit-activo').checked    = activo === 1;
    document.getElementById('edit-estacion').value    = estacionId || '';
    document.getElementById('form-editar-categoria').action = `/admin/categorias/${id}/editar`;
    document.getElementById('modal-editar-categoria').style.display = 'flex';
  }

  // Eliminar categoría
  async function eliminarCategoria(id, nombre) {
    if (!confirm(`¿Estás seguro de eliminar la categoría "${nombre}"?\n\nEsta acción también eliminará todos sus ítems y no se puede deshacer.`)) return;
    try {
      const r = await fetch(`/admin/categorias/${id}`, { method: 'DELETE', credentials: 'include' });
      const data = await r.json();
      if (data.success) {
        location.reload();
      } else {
        alert('❌ Error al eliminar: ' + data.mensaje);
      }
    } catch (e) {
      alert('❌ Error de conexión al eliminar la categoría.');
    }
  }
  </script>
</body>
</html>
