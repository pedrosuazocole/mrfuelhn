<!DOCTYPE html>
<html lang="es-HN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | Mr. Fuel v2.0</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">
        <i class="fab fa-whatsapp"></i> Gestión de WhatsApp
      </h1>
      <button class="btn btn-primary" data-toggle-modal="nuevo-numero">
        <i class="fas fa-plus"></i> Agregar Número
      </button>
    </div>
    
    <div class="card">
      <p style="padding: 20px; background: #e7f3ff; border-left: 4px solid #2196F3; margin: 0 0 20px 0;">
        <i class="fas fa-info-circle"></i> <strong>Nota:</strong> Los números activos recibirán el enlace de la auditoría por WhatsApp después de guardarla.
      </p>
      
      <% if (numeros.length === 0) { %>
        <div style="text-align: center; padding: 40px; color: #666;">
          <i class="fab fa-whatsapp" style="font-size: 64px; margin-bottom: 20px; opacity: 0.3;"></i>
          <p style="font-size: 18px;">No hay números configurados</p>
          <button class="btn btn-primary" data-toggle-modal="nuevo-numero" style="margin-top: 20px;">
            <i class="fas fa-plus"></i> Agregar Primer Número
          </button>
        </div>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Número</th>
              <th>Cargo</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% numeros.forEach(num => { %>
            <tr>
              <td><strong><%= num.nombre %></strong></td>
              <td>
                <i class="fab fa-whatsapp" style="color: #25D366;"></i> 
                <%= num.numero %>
              </td>
              <td><%= num.cargo || '-' %></td>
              <td>
                <span class="badge <%= num.activo ? 'badge-success' : 'badge-danger' %>">
                  <%= num.activo ? 'Activo' : 'Inactivo' %>
                </span>
              </td>
              <td>
                <button class="btn btn-sm btn-secondary" title="Editar" 
                        onclick="editarNumero(<%= num.id %>, '<%= num.nombre %>', '<%= num.numero %>', '<%= num.cargo || '' %>')">
                  <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-sm <%= num.activo ? 'btn-warning' : 'btn-success' %>" 
                        title="<%= num.activo ? 'Desactivar' : 'Activar' %>"
                        onclick="toggleActivo(<%= num.id %>)">
                  <i class="fas fa-<%= num.activo ? 'toggle-on' : 'toggle-off' %>"></i>
                </button>
                <button class="btn btn-sm btn-danger" title="Eliminar" onclick="eliminarNumero(<%= num.id %>, '<%= num.nombre %>')">
                  <i class="fas fa-trash"></i>
                </button>
                <a href="https://wa.me/<%= num.numero.replace(/[^0-9]/g, '') %>" 
                   target="_blank" 
                   class="btn btn-sm btn-success" 
                   title="Probar en WhatsApp">
                  <i class="fab fa-whatsapp"></i>
                </a>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>
  
  <!-- Modal: Nuevo Número -->
  <div id="modal-nuevo-numero" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Agregar Número de WhatsApp</h2>
        <button class="modal-close" onclick="cerrarModal('modal-nuevo-numero')">&times;</button>
      </div>
      <form action="/admin/whatsapp/nuevo" method="POST">
        <div class="form-group">
          <label>Nombre *</label>
          <input type="text" name="nombre" required class="form-control" placeholder="Ej: Juan Pérez">
        </div>
        
        <div class="form-group">
          <label>Número WhatsApp *</label>
          <input type="text" name="numero" required class="form-control" placeholder="+504 9999-9999">
          <small class="form-text">Incluir código de país. Ej: +504 para Honduras</small>
        </div>
        
        <div class="form-group">
          <label>Cargo</label>
          <input type="text" name="cargo" class="form-control" placeholder="Ej: Supervisor">
        </div>
        
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-nuevo-numero')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar Número</button>
        </div>
      </form>
    </div>
  </div>
  
  <!-- Modal: Editar Número -->
  <div id="modal-editar-numero" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Editar Número de WhatsApp</h2>
        <button class="modal-close" onclick="cerrarModal('modal-editar-numero')">&times;</button>
      </div>
      <form id="form-editar-numero" method="POST">
        <div class="form-group">
          <label>Nombre *</label>
          <input type="text" id="edit-nombre" name="nombre" required class="form-control">
        </div>
        
        <div class="form-group">
          <label>Número WhatsApp *</label>
          <input type="text" id="edit-numero" name="numero" required class="form-control">
          <small class="form-text">Incluir código de país</small>
        </div>
        
        <div class="form-group">
          <label>Cargo</label>
          <input type="text" id="edit-cargo" name="cargo" class="form-control">
        </div>
        
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-editar-numero')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Actualizar Número</button>
        </div>
      </form>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
  
  <script>
  // Abrir modal nuevo número
  document.querySelectorAll('[data-toggle-modal="nuevo-numero"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('modal-nuevo-numero').style.display = 'flex';
    });
  });
  
  // Cerrar modal
  function cerrarModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
  }
  
  // Cerrar modal al hacer clic fuera
  window.addEventListener('click', (e) => {
    if (e.target.classList.contains('modal')) {
      e.target.style.display = 'none';
    }
  });
  
  // Editar número
  function editarNumero(id, nombre, numero, cargo) {
    document.getElementById('edit-nombre').value = nombre;
    document.getElementById('edit-numero').value = numero;
    document.getElementById('edit-cargo').value = cargo || '';
    document.getElementById('form-editar-numero').action = `/admin/whatsapp/${id}/editar`;
    document.getElementById('modal-editar-numero').style.display = 'flex';
  }
  
  // Toggle activo/inactivo
  function toggleActivo(id) {
    if (confirm('¿Cambiar estado del número?')) {
      fetch(`/admin/whatsapp/${id}/toggle`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          alert('Error al cambiar estado');
        }
      });
    }
  }
  
  // Eliminar número
  function eliminarNumero(id, nombre) {
    if (confirm(`¿Eliminar el número de ${nombre}?`)) {
      fetch(`/admin/whatsapp/${id}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert('Número eliminado');
          location.reload();
        } else {
          alert('Error al eliminar');
        }
      });
    }
  }
  </script>
</body>
</html>
