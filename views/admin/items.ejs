<!DOCTYPE html>
<html lang="es-HN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | Mr. Fuel v2.0</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">
        <i class="fas fa-list"></i> <%= titulo %>
      </h1>
      <div>
        <a href="/admin/categorias" class="btn btn-secondary">
          <i class="fas fa-arrow-left"></i> Volver a Categorías
        </a>
        <button class="btn btn-primary" data-toggle-modal="nuevo-item">
          <i class="fas fa-plus"></i> Nuevo Ítem
        </button>
      </div>
    </div>
    
    <!-- Información de la Categoría -->
    <div class="card">
      <div class="card-header" style="background: #ED1C24; color: white;">
        <%= categoria.nombre %>
      </div>
      <div style="padding: 20px;">
        <p><strong>Descripción:</strong> <%= categoria.descripcion || 'Sin descripción' %></p>
        <p><strong>Orden:</strong> <%= categoria.orden %></p>
        <p><strong>Estado:</strong> 
          <span class="badge <%= categoria.activo ? 'badge-success' : 'badge-danger' %>">
            <%= categoria.activo ? 'Activa' : 'Inactiva' %>
          </span>
        </p>
      </div>
    </div>
    
    <!-- Lista de Ítems -->
    <% if (items.length === 0) { %>
      <div class="card">
        <div style="text-align: center; padding: 40px; color: #666;">
          <i class="fas fa-clipboard-list" style="font-size: 64px; margin-bottom: 20px; opacity: 0.3;"></i>
          <p style="font-size: 18px;">No hay ítems en esta categoría</p>
          <button class="btn btn-primary" data-toggle-modal="nuevo-item" style="margin-top: 20px;">
            <i class="fas fa-plus"></i> Agregar Primer Ítem
          </button>
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <table class="table">
          <thead>
            <tr>
              <th>Orden</th>
              <th>Nombre</th>
              <th>Descripción</th>
              <th>Max Fotos</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
            <tr>
              <td><strong><%= item.orden %></strong></td>
              <td><%= item.nombre %></td>
              <td><%= item.descripcion || '-' %></td>
              <td><%= item.max_fotos %></td>
              <td>
                <span class="badge <%= item.activo ? 'badge-success' : 'badge-danger' %>">
                  <%= item.activo ? 'Activo' : 'Inactivo' %>
                </span>
              </td>
              <td>
                <button class="btn btn-sm btn-secondary" title="Editar" onclick="editarItem(<%= item.id %>, '<%= item.nombre %>', '<%= item.descripcion || '' %>', <%= item.max_fotos %>, <%= item.orden %>)">
                  <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-sm btn-danger" title="Eliminar" onclick="eliminarItem(<%= item.id %>, '<%= item.nombre %>')">
                  <i class="fas fa-trash"></i>
                </button>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
    
    <!-- Resumen -->
    <div class="card">
      <div style="padding: 20px;">
        <h3>📊 Resumen</h3>
        <p><strong>Total de ítems:</strong> <%= items.length %></p>
        <p><strong>Ítems activos:</strong> <%= items.filter(i => i.activo).length %></p>
        <p><strong>Ítems inactivos:</strong> <%= items.filter(i => !i.activo).length %></p>
      </div>
    </div>
  </main>
  
  <!-- Modal: Nuevo Ítem -->
  <div id="modal-nuevo-item" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Nuevo Ítem</h2>
        <button class="modal-close" onclick="cerrarModal('modal-nuevo-item')">&times;</button>
      </div>
      <form action="/admin/items/nuevo" method="POST">
        <input type="hidden" name="categoria_id" value="<%= categoria.id %>">
        
        <div class="form-group">
          <label>Nombre del Ítem *</label>
          <input type="text" name="nombre" required class="form-control" placeholder="Ej: Uniformes">
        </div>
        
        <div class="form-group">
          <label>Descripción</label>
          <textarea name="descripcion" class="form-control" rows="3" placeholder="Descripción detallada (opcional)"></textarea>
        </div>
        
        <div class="form-group">
          <label>Máximo de Fotos</label>
          <input type="number" name="max_fotos" value="3" min="0" max="10" class="form-control">
        </div>
        
        <div class="form-group">
          <label>Orden</label>
          <input type="number" name="orden" value="<%= items.length + 1 %>" min="1" class="form-control">
        </div>
        
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-nuevo-item')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar Ítem</button>
        </div>
      </form>
    </div>
  </div>
  
  <!-- Modal: Editar Ítem -->
  <div id="modal-editar-item" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Editar Ítem</h2>
        <button class="modal-close" onclick="cerrarModal('modal-editar-item')">&times;</button>
      </div>
      <form id="form-editar-item" method="POST">
        <div class="form-group">
          <label>Nombre del Ítem *</label>
          <input type="text" id="edit-nombre" name="nombre" required class="form-control">
        </div>
        
        <div class="form-group">
          <label>Descripción</label>
          <textarea id="edit-descripcion" name="descripcion" class="form-control" rows="3"></textarea>
        </div>
        
        <div class="form-group">
          <label>Máximo de Fotos</label>
          <input type="number" id="edit-max-fotos" name="max_fotos" value="3" min="0" max="10" class="form-control">
        </div>
        
        <div class="form-group">
          <label>Orden</label>
          <input type="number" id="edit-orden" name="orden" min="1" class="form-control">
        </div>
        
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-editar-item')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Actualizar Ítem</button>
        </div>
      </form>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
  
  <script>
  // Abrir modal de nuevo ítem
  document.querySelectorAll('[data-toggle-modal="nuevo-item"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('modal-nuevo-item').style.display = 'flex';
    });
  });
  
  // Cerrar modal
  function cerrarModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
  }
  
  // Cerrar modal al hacer clic fuera
  window.addEventListener('click', (e) => {
    if (e.target.classList.contains('modal')) {
      e.target.style.display = 'none';
    }
  });
  
  // Editar ítem
  function editarItem(id, nombre, descripcion, maxFotos, orden) {
    document.getElementById('edit-nombre').value = nombre;
    document.getElementById('edit-descripcion').value = descripcion || '';
    document.getElementById('edit-max-fotos').value = maxFotos;
    document.getElementById('edit-orden').value = orden;
    document.getElementById('form-editar-item').action = `/admin/items/${id}/editar`;
    document.getElementById('modal-editar-item').style.display = 'flex';
  }
  
  // Eliminar ítem
  function eliminarItem(id, nombre) {
    if (confirm(`¿Estás seguro de eliminar el ítem "${nombre}"?`)) {
      fetch(`/admin/items/${id}`, {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(response => {
        if (response.ok) {
          alert('Ítem eliminado exitosamente');
          location.reload();
        } else {
          alert('Error al eliminar el ítem');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error al eliminar el ítem');
      });
    }
  }
  </script>
</body>
</html>
