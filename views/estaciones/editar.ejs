<!DOCTYPE html>
<html lang="es-HN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | Mr. Fuel</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">
        <i class="fas fa-edit"></i> Editar Estación
      </h1>
    </div>
    
    <div class="card">
      <form method="POST" action="/estaciones/editar/<%= estacion.id %>">
        <div class="card-header">Información de la Estación</div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="nombre">Nombre de la Estación *</label>
            <input type="text" name="nombre" id="nombre" class="form-control" required value="<%= estacion.nombre %>">
          </div>
          
          <div class="form-group">
            <label for="codigo">Código *</label>
            <input type="text" name="codigo" id="codigo" class="form-control" required value="<%= estacion.codigo %>">
          </div>
        </div>
        
        <div class="form-group">
          <label for="direccion">Dirección Completa *</label>
          <input type="text" name="direccion" id="direccion" class="form-control" required value="<%= estacion.direccion %>">
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="ciudad">Ciudad *</label>
            <input type="text" name="ciudad" id="ciudad" class="form-control" required value="<%= estacion.ciudad %>">
          </div>
          
          <div class="form-group">
            <label for="departamento">Departamento *</label>
            <select name="departamento" id="departamento" class="form-control" required>
              <option value="">Seleccionar...</option>
              <option value="Atlántida" <%= estacion.departamento === 'Atlántida' ? 'selected' : '' %>>Atlántida</option>
              <option value="Colón" <%= estacion.departamento === 'Colón' ? 'selected' : '' %>>Colón</option>
              <option value="Comayagua" <%= estacion.departamento === 'Comayagua' ? 'selected' : '' %>>Comayagua</option>
              <option value="Copán" <%= estacion.departamento === 'Copán' ? 'selected' : '' %>>Copán</option>
              <option value="Cortés" <%= estacion.departamento === 'Cortés' ? 'selected' : '' %>>Cortés</option>
              <option value="Choluteca" <%= estacion.departamento === 'Choluteca' ? 'selected' : '' %>>Choluteca</option>
              <option value="El Paraíso" <%= estacion.departamento === 'El Paraíso' ? 'selected' : '' %>>El Paraíso</option>
              <option value="Francisco Morazán" <%= estacion.departamento === 'Francisco Morazán' ? 'selected' : '' %>>Francisco Morazán</option>
              <option value="Gracias a Dios" <%= estacion.departamento === 'Gracias a Dios' ? 'selected' : '' %>>Gracias a Dios</option>
              <option value="Intibucá" <%= estacion.departamento === 'Intibucá' ? 'selected' : '' %>>Intibucá</option>
              <option value="Islas de la Bahía" <%= estacion.departamento === 'Islas de la Bahía' ? 'selected' : '' %>>Islas de la Bahía</option>
              <option value="La Paz" <%= estacion.departamento === 'La Paz' ? 'selected' : '' %>>La Paz</option>
              <option value="Lempira" <%= estacion.departamento === 'Lempira' ? 'selected' : '' %>>Lempira</option>
              <option value="Ocotepeque" <%= estacion.departamento === 'Ocotepeque' ? 'selected' : '' %>>Ocotepeque</option>
              <option value="Olancho" <%= estacion.departamento === 'Olancho' ? 'selected' : '' %>>Olancho</option>
              <option value="Santa Bárbara" <%= estacion.departamento === 'Santa Bárbara' ? 'selected' : '' %>>Santa Bárbara</option>
              <option value="Valle" <%= estacion.departamento === 'Valle' ? 'selected' : '' %>>Valle</option>
              <option value="Yoro" <%= estacion.departamento === 'Yoro' ? 'selected' : '' %>>Yoro</option>
            </select>
          </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="telefono">Teléfono</label>
            <input type="tel" name="telefono" id="telefono" class="form-control" value="<%= estacion.telefono || '' %>">
          </div>
          
          <div class="form-group">
            <label for="encargado">Nombre del Encargado</label>
            <input type="text" name="encargado" id="encargado" class="form-control" value="<%= estacion.encargado || '' %>">
          </div>
        </div>
        
        <div class="card-header" style="margin-top: 20px;">Geolocalización (Opcional)</div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="latitud">Latitud</label>
            <input type="number" step="any" name="latitud" id="latitud" class="form-control" value="<%= estacion.latitud || '' %>">
          </div>
          
          <div class="form-group">
            <label for="longitud">Longitud</label>
            <input type="number" step="any" name="longitud" id="longitud" class="form-control" value="<%= estacion.longitud || '' %>">
          </div>
        </div>
        
        <div class="form-group">
          <label>
            <input type="checkbox" name="activo" id="activo" <%= estacion.activo ? 'checked' : '' %>>
            Estación Activa
          </label>
        </div>
        
        <div style="display: flex; gap: 15px; justify-content: flex-end; margin-top: 30px;">
          <a href="/estaciones" class="btn btn-secondary">
            <i class="fas fa-times"></i> Cancelar
          </a>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Guardar Cambios
          </button>
        </div>
      </form>
    </div>
  </main>
  
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
