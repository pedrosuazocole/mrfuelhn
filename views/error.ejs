<!DOCTYPE html>
<html lang="es-HN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | Mr. Fuel</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <% if (user && user.userId) { %>
    <%- include('partials/header') %>
  <% } %>
  
  <main class="main-content">
    <div style="text-align: center; padding: 60px 20px;">
      <div style="font-size: 120px; color: var(--texaco-red); margin-bottom: 30px;">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      
      <h1 style="font-size: 48px; margin-bottom: 15px; color: #333;"><%= codigo %></h1>
      <h2 style="font-size: 32px; margin-bottom: 20px; color: #666;"><%= titulo %></h2>
      <p style="font-size: 18px; color: #999; margin-bottom: 40px;"><%= mensaje %></p>
      
      <div style="display: flex; gap: 15px; justify-content: center;">
        <a href="javascript:history.back()" class="btn btn-secondary">
          <i class="fas fa-arrow-left"></i> Volver
        </a>
        <a href="/dashboard" class="btn btn-primary">
          <i class="fas fa-home"></i> Ir al Dashboard
        </a>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
</body>
</html>
