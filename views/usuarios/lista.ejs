<!DOCTYPE html>
<html lang="es-HN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | Mr. Fuel</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">
        <i class="fas fa-users"></i> Usuarios del Sistema
      </h1>
      <button class="btn btn-primary" data-accion="nuevo-usuario">
        <i class="fas fa-plus"></i> Nuevo Usuario
      </button>
    </div>
    
    <div class="card">
      <% if (usuarios.length === 0) { %>
        <div style="text-align: center; padding: 40px;">
          <div style="font-size: 64px; color: #ccc; margin-bottom: 15px;">
            <i class="fas fa-users"></i>
          </div>
          <p class="text-muted">No hay usuarios registrados.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Teléfono</th>
                <th>Estado</th>
                <th>Fecha Creación</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% usuarios.forEach(usr => { %>
              <tr>
                <td><strong>#<%= usr.id %></strong></td>
                <td><%= usr.nombre %></td>
                <td><%= usr.email %></td>
                <td>
                  <% if (usr.rol === 'admin') { %>
                    <span class="badge badge-danger">Administrador</span>
                  <% } else if (usr.rol === 'supervisor') { %>
                    <span class="badge badge-warning">Supervisor</span>
                  <% } else { %>
                    <span class="badge badge-success">Auditor</span>
                  <% } %>
                </td>
                <td><%= usr.telefono || '-' %></td>
                <td>
                  <% if (usr.activo) { %>
                    <span class="badge badge-success">Activo</span>
                  <% } else { %>
                    <span class="badge badge-danger">Inactivo</span>
                  <% } %>
                </td>
                <td><%= new Date(usr.fecha_creacion).toLocaleDateString('es-HN') %></td>
                <td>
                  <a href="/usuarios/editar/<%= usr.id %>" class="btn btn-sm btn-secondary" title="Editar">
                    <i class="fas fa-edit"></i>
                  </a>
                  <% if (usr.id !== user.userId) { %>
                  <button class="btn btn-sm btn-secondary" data-eliminar-usuario="<%= usr.id %>" title="Eliminar">
                    <i class="fas fa-trash"></i>
                  </button>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
  
  <%- include('../partials/footer') %>
  
  <!-- MODAL NUEVO USUARIO -->
  <div id="modalNuevoUsuario" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: white; padding: 30px; border-radius: 8px; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
      <h2 style="margin-bottom: 20px; color: var(--texaco-red);">
        <i class="fas fa-user-plus"></i> Nuevo Usuario
      </h2>
      
      <form id="formNuevoUsuario">
        <div class="form-group">
          <label for="nombre">Nombre Completo *</label>
          <input type="text" name="nombre" id="nombre" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" name="email" id="email" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="password">Contraseña *</label>
          <input type="password" name="password" id="password" class="form-control" required minlength="6">
          <small class="text-muted">Mínimo 6 caracteres</small>
        </div>
        
        <div class="form-group">
          <label for="rol">Rol *</label>
          <select name="rol" id="rol" class="form-control" required>
            <option value="">Seleccionar...</option>
            <option value="auditor">Auditor</option>
            <option value="supervisor">Supervisor</option>
            <option value="admin">Administrador</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="telefono">Teléfono</label>
          <input type="tel" name="telefono" id="telefono" class="form-control" placeholder="9999-9999">
        </div>
        
        <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 25px;">
          <button type="button" class="btn btn-secondary" data-accion="cerrar-modal">
            <i class="fas fa-times"></i> Cancelar
          </button>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Crear Usuario
          </button>
        </div>
      </form>
    </div>
  </div>
  
  <script src="/js/main.js"></script>
  <script>
    // Mostrar modal
    document.querySelector('[data-accion="nuevo-usuario"]').addEventListener('click', () => {
      document.getElementById('modalNuevoUsuario').style.display = 'flex';
    });
    
    // Cerrar modal
    document.querySelector('[data-accion="cerrar-modal"]').addEventListener('click', () => {
      document.getElementById('modalNuevoUsuario').style.display = 'none';
    });
    
    // Cerrar al hacer click fuera
    document.getElementById('modalNuevoUsuario').addEventListener('click', (e) => {
      if (e.target.id === 'modalNuevoUsuario') {
        document.getElementById('modalNuevoUsuario').style.display = 'none';
      }
    });
    
    // Enviar formulario
    document.getElementById('formNuevoUsuario').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      
      try {
        const response = await fetch('/usuarios/nuevo', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
          alert('✅ Usuario creado exitosamente');
          window.location.reload();
        } else {
          alert('❌ Error: ' + result.mensaje);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('❌ Error al crear usuario');
      }
    });
  </script>
  
  <script>
    // Eliminar usuario
    document.addEventListener('click', async (e) => {
      if (e.target.matches('[data-eliminar-usuario]') || e.target.closest('[data-eliminar-usuario]')) {
        e.preventDefault();
        
        const btn = e.target.closest('[data-eliminar-usuario]');
        const usuarioId = btn.dataset.eliminarUsuario;
        
        if (!confirm('¿Estás seguro de eliminar este usuario? Esta acción no se puede deshacer.')) {
          return;
        }
        
        try {
          const response = await fetch(`/usuarios/eliminar/${usuarioId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          
          const result = await response.json();
          
          if (result.success) {
            alert('✅ Usuario eliminado correctamente');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.mensaje);
          }
        } catch (error) {
          console.error('Error:', error);
          alert('❌ Error al eliminar usuario');
        }
      }
    });
  </script>
</body>
</html>
