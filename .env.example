# ===================================
# CONFIGURACIÓN MR. FUEL
# Sistema de Cliente Misterioso - Texaco
# ===================================

# SERVIDOR
PORT=3000
NODE_ENV=development

# SESSION SECRET (cambiar en producción)
SESSION_SECRET=mr_fuel_texaco_secret_key_2024_change_this

# ===================================
# MR. FUEL V2.0 - CONFIGURACIÓN
# ===================================

# ENTORNO
NODE_ENV=development
PORT=3000

# SESIONES
SESSION_SECRET=mr-fuel-secret-key-change-this-in-production

# BASE DE DATOS
# En desarrollo: ./database/mrfuel.db
# En producción (Railway): /tmp/mrfuel.db o /data/mrfuel.db (con volumen)
DB_PATH=./database/mrfuel.db

# ===================================
# EMAIL - RESEND (Recomendado)
# ===================================
EMAIL_SERVICE=resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Mr. Fuel <onboarding@resend.dev>

# ===================================
# EMAIL - SMTP (Alternativa: Brevo, Gmail, etc)
# ===================================
# Si no usas Resend, descomentar estas líneas:
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@smtp-brevo.com
# EMAIL_PASS=your-smtp-key
# EMAIL_FROM=Mr. Fuel <your-email@smtp-brevo.com>

# ===================================
# DESTINATARIOS DE NOTIFICACIONES
# ===================================
ADMIN_EMAILS=admin1@texaco.com,admin2@texaco.com
SUPERVISOR_EMAILS=supervisor1@texaco.com,supervisor2@texaco.com

# ===================================
# RECORDATORIOS AUTOMÁTICOS
# ===================================
REMINDER_DAYS=1,3,5
REMINDER_HOUR=08
REMINDER_MINUTE=00

# ===================================
# SISTEMA
# ===================================
TZ=America/Tegucigalpa
BRAND_NAME=Texaco

# ===================================
# ARCHIVOS
# ===================================
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp
MAX_FILE_SIZE=5242880

# ===================================
# RAILWAY (Solo para producción)
# ===================================
# Descomentar si usas Railway con volumen persistente:
# RAILWAY_VOLUME_MOUNT_PATH=/data
# APP_URL=https://mrfuel-production.up.railway.app

# EMAIL CONFIGURATION (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-contraseña-de-aplicación
EMAIL_FROM=Mr. Fuel Texaco <tu-email@gmail.com>

# EMAILS DE NOTIFICACIÓN (separados por comas)
ADMIN_EMAILS=admin1@texaco.com,admin2@texaco.com
SUPERVISOR_EMAILS=supervisor1@texaco.com,supervisor2@texaco.com

# RECORDATORIOS AUTOMÁTICOS
# Días de la semana para recordatorios (0=Domingo, 1=Lunes, ..., 6=Sábado)
REMINDER_DAYS=1,3,5
# Hora del recordatorio (formato 24h)
REMINDER_HOUR=08
REMINDER_MINUTE=00

# TIMEZONE
TZ=America/Tegucigalpa

# UPLOADS
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# TEXACO BRAND
BRAND_NAME=Texaco
BRAND_COLOR=#ED1C24
BRAND_SECONDARY=#000000
